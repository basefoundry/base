#
# zshrc
#     Base-managed interactive-shell integration for Zsh dotfiles.
#
# Purpose:
#     - source user-managed ~/.baserc preferences when present
#     - derive and export BASE_HOME from this snippet's location
#     - make basectl available on PATH
#     - source optional Zsh defaults when enabled in ~/.base.d/profile.conf
#     - print startup diagnostics when BASE_DEBUG=1 is set
#
# Important:
#     This file must not source base_init.sh. Base runtime setup belongs to the
#     Bash-based basectl command path, not ordinary Zsh startup.
#
base_zshrc_debug() {
    case "${BASE_DEBUG:-}" in
        1|true|TRUE|yes|YES|on|ON)
            printf 'BASE_DEBUG zshrc: %s\n' "$*" >&2
            ;;
    esac
}

base_zshrc_snippet_dir() {
    local source_path

    source_path="$(eval 'printf "%s\n" "${(%):-%x}"')" || return 1
    [[ -n "$source_path" ]] || return 1

    cd -- "$(dirname -- "$source_path")" && pwd -P
}

base_zshrc_source_baserc_guard() {
    local snippet_dir
    local guard_path

    snippet_dir="$(base_zshrc_snippet_dir)" || return 1
    guard_path="$snippet_dir/zsh_baserc_guard.zsh"

    [[ -f "$guard_path" ]] || {
        printf "ERROR: Base Zsh baserc guard '%s' was not found.\n" "$guard_path" >&2
        return 1
    }

    source "$guard_path"
}

base_zshrc_source_baserc_guard || return $?
base_zsh_baserc_guard_source base_zshrc_debug || return $?

if [[ ! -o interactive ]]; then
    base_zshrc_debug "non-interactive shell; skipping"
    unset -f base_zshrc_debug base_zshrc_snippet_dir base_zshrc_source_baserc_guard
    return 0
fi

if [[ -n "${__base_zshrc_sourced__:-}" ]]; then
    base_zshrc_debug "already sourced; skipping"
    unset -f base_zshrc_debug base_zshrc_snippet_dir base_zshrc_source_baserc_guard
    return 0
fi
readonly __base_zshrc_sourced__=1
base_zshrc_debug "loading"

base_zshrc_set_base_home() {
    local snippet_dir
    local base_home

    snippet_dir="$(base_zshrc_snippet_dir)" || return 1
    base_home="$(cd -- "$snippet_dir/../.." && pwd -P)" || return 1

    [[ -f "$base_home/base_init.sh" ]] || return 1
    export BASE_HOME="$base_home"
    base_zshrc_debug "BASE_HOME=$BASE_HOME"
}

base_zshrc_source_platform_tools_helper() {
    local snippet_dir
    local helper_path

    snippet_dir="$(base_zshrc_snippet_dir)" || return 1
    helper_path="$snippet_dir/base_platform_tools.sh"

    [[ -f "$helper_path" ]] || {
        printf "ERROR: Base Platform Tools helper '%s' was not found.\n" "$helper_path" >&2
        return 1
    }

    source "$helper_path"
}

base_zshrc_configure_path() {
    local base_bin="$BASE_HOME/bin"
    local previous_path="$PATH"
    local platform_tools_bin=""

    [[ -d "$base_bin" ]] || {
        base_zshrc_debug "bin dir '$base_bin' does not exist; PATH unchanged"
        return 0
    }

    base_zshrc_source_platform_tools_helper || return $?
    if base_platform_tools_detect "$BASE_HOME"; then
        platform_tools_bin="$BASE_PLATFORM_TOOLS_BIN_DIR"
    fi

    base_platform_tools_set_ordered_path "$base_bin" "$platform_tools_bin" ""
    if [[ "$PATH" == "$previous_path" ]]; then
        base_zshrc_debug "PATH already contains required Base entries"
    elif [[ -n "$platform_tools_bin" ]]; then
        base_zshrc_debug "configured PATH with '$base_bin' and '$platform_tools_bin'"
    else
        base_zshrc_debug "prepended '$base_bin' to PATH"
    fi
}

base_zshrc_source_defaults() {
    local profile_conf="$HOME/.base.d/profile.conf"
    local enable_defaults=false

    if [[ ! -f "$profile_conf" ]]; then
        base_zshrc_debug "profile config '$profile_conf' not found; defaults disabled"
        return 0
    fi

    base_zshrc_debug "sourcing profile config '$profile_conf'"
    # shellcheck source=/dev/null
    source "$profile_conf"
    enable_defaults="${BASE_ENABLE_ZSH_DEFAULTS:-false}"
    unset BASE_PROFILE_VERSION BASE_ENABLE_BASH_DEFAULTS BASE_ENABLE_ZSH_DEFAULTS

    if [[ "$enable_defaults" != true ]]; then
        base_zshrc_debug "Zsh defaults disabled"
        return 0
    fi

    if [[ ! -f "$BASE_HOME/lib/shell/zsh_defaults.sh" ]]; then
        base_zshrc_debug "Zsh defaults file not found; skipping"
        return 0
    fi

    base_zshrc_debug "sourcing Zsh defaults"
    # shellcheck source=/dev/null
    source "$BASE_HOME/lib/shell/zsh_defaults.sh"
}

base_zshrc_source_completions() {
    local completion_file="$BASE_HOME/lib/shell/completions/basectl_completion.zsh"

    if [[ ! -f "$completion_file" ]]; then
        base_zshrc_debug "Zsh completion file not found; skipping"
        return 0
    fi

    base_zshrc_debug "sourcing Zsh completions"
    source "$completion_file"
}

base_zshrc_set_base_home || {
    printf 'ERROR: Unable to determine BASE_HOME from Base zshrc snippet. Run basectl update-profile.\n' >&2
    unset -f base_zshrc_debug base_zshrc_snippet_dir base_zshrc_source_baserc_guard
    return 1
}
base_zshrc_configure_path || return $?
base_zshrc_source_defaults || return 1
base_zshrc_source_completions || return 1
base_zshrc_debug "complete"

unset -f base_zshrc_snippet_dir base_zshrc_set_base_home
unset -f base_zshrc_source_platform_tools_helper base_zshrc_configure_path base_zshrc_source_defaults
unset -f base_zshrc_source_completions
unset -f base_zshrc_source_baserc_guard base_zshrc_debug
