#
# bashrc
#     Base-managed interactive-shell integration for Bash dotfiles.
#
# Purpose:
#     - source user-managed ~/.baserc preferences when present
#     - derive and export BASE_HOME from this snippet's location
#     - make basectl available on PATH
#     - source optional Bash defaults when enabled in ~/.base.d/profile.conf
#     - print startup diagnostics when BASE_DEBUG=1 is set
#
# Important:
#     This file must not source base_init.sh. Base runtime setup belongs to the
#     basectl command path, not ordinary shell startup.
#
base_bashrc_debug() {
    case "${BASE_DEBUG:-}" in
        1|true|TRUE|yes|YES|on|ON)
            printf 'BASE_DEBUG bashrc: %s\n' "$*" >&2
            ;;
    esac
}

base_bashrc_snippet_dir() {
    cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P
}

base_bashrc_source_baserc_guard() {
    local snippet_dir
    local guard_path

    snippet_dir="$(base_bashrc_snippet_dir)" || return 1
    guard_path="$snippet_dir/baserc_guard.sh"

    [[ -f "$guard_path" ]] || {
        printf "ERROR: Base baserc guard '%s' was not found.\n" "$guard_path" >&2
        return 1
    }

    # shellcheck source=/dev/null
    source "$guard_path"
}

base_bashrc_var_is_readonly() {
    local declaration

    declaration="$(declare -p "$1" 2>/dev/null)" || return 1
    [[ "$declaration" == declare\ -*r* ]]
}

base_bashrc_source_baserc_guard || return $?
base_baserc_guard_source base_bashrc_debug || return $?

if [[ $- != *i* ]]; then
    base_bashrc_debug "non-interactive shell; skipping"
    unset -f base_bashrc_debug base_bashrc_snippet_dir base_bashrc_source_baserc_guard base_bashrc_var_is_readonly
    return 0
fi

if [[ -n "${__base_bashrc_sourced__:-}" ]]; then
    base_bashrc_debug "already sourced; skipping"
    unset -f base_bashrc_debug base_bashrc_snippet_dir base_bashrc_source_baserc_guard base_bashrc_var_is_readonly
    return 0
fi
readonly __base_bashrc_sourced__=1
base_bashrc_debug "loading"

base_bashrc_set_base_home() {
    local snippet_dir
    local base_home

    snippet_dir="$(base_bashrc_snippet_dir)" || return 1
    base_home="$(cd -- "$snippet_dir/../.." && pwd -P)" || return 1

    [[ -f "$base_home/base_init.sh" ]] || return 1
    if [[ -n "${BASE_HOME+x}" ]]; then
        if [[ "$BASE_HOME" == "$base_home" ]]; then
            export BASE_HOME
            base_bashrc_debug "BASE_HOME=$BASE_HOME"
            return 0
        fi
        if base_bashrc_var_is_readonly BASE_HOME; then
            printf "ERROR: BASE_HOME is readonly and points at '%s', not '%s'.\n" "$BASE_HOME" "$base_home" >&2
            return 1
        fi
    fi
    export BASE_HOME="$base_home"
    base_bashrc_debug "BASE_HOME=$BASE_HOME"
}

base_bashrc_source_platform_tools_helper() {
    local snippet_dir
    local helper_path

    snippet_dir="$(base_bashrc_snippet_dir)" || return 1
    helper_path="$snippet_dir/base_platform_tools.sh"

    [[ -f "$helper_path" ]] || {
        printf "ERROR: Base Platform Tools helper '%s' was not found.\n" "$helper_path" >&2
        return 1
    }

    # shellcheck source=/dev/null
    source "$helper_path"
}

base_bashrc_configure_path() {
    local base_bin="$BASE_HOME/bin"
    local previous_path="$PATH"
    local platform_tools_bin=""

    [[ -d "$base_bin" ]] || {
        base_bashrc_debug "bin dir '$base_bin' does not exist; PATH unchanged"
        return 0
    }

    base_bashrc_source_platform_tools_helper || return $?
    if base_platform_tools_detect "$BASE_HOME"; then
        platform_tools_bin="$BASE_PLATFORM_TOOLS_BIN_DIR"
    fi

    base_platform_tools_set_ordered_path "$base_bin" "$platform_tools_bin" ""
    if [[ "$PATH" == "$previous_path" ]]; then
        base_bashrc_debug "PATH already contains required Base entries"
    elif [[ -n "$platform_tools_bin" ]]; then
        base_bashrc_debug "configured PATH with '$base_bin' and '$platform_tools_bin'"
    else
        base_bashrc_debug "prepended '$base_bin' to PATH"
    fi
}

base_bashrc_source_defaults() {
    local profile_conf="$HOME/.base.d/profile.conf"
    local enable_defaults=false

    if [[ ! -f "$profile_conf" ]]; then
        base_bashrc_debug "profile config '$profile_conf' not found; defaults disabled"
        return 0
    fi

    base_bashrc_debug "sourcing profile config '$profile_conf'"
    # shellcheck source=/dev/null
    source "$profile_conf"
    enable_defaults="${BASE_ENABLE_BASH_DEFAULTS:-false}"
    unset BASE_PROFILE_VERSION BASE_ENABLE_BASH_DEFAULTS BASE_ENABLE_ZSH_DEFAULTS

    if [[ "$enable_defaults" != true ]]; then
        base_bashrc_debug "Bash defaults disabled"
        return 0
    fi

    if [[ ! -f "$BASE_HOME/lib/shell/bash_defaults.sh" ]]; then
        base_bashrc_debug "Bash defaults file not found; skipping"
        return 0
    fi

    base_bashrc_debug "sourcing Bash defaults"
    # shellcheck source=/dev/null
    source "$BASE_HOME/lib/shell/bash_defaults.sh"
}

base_bashrc_source_completions() {
    local completion_file="$BASE_HOME/lib/shell/completions/basectl_completion.sh"

    if [[ ! -f "$completion_file" ]]; then
        base_bashrc_debug "Bash completion file not found; skipping"
        return 0
    fi

    if ! type complete >/dev/null 2>&1; then
        base_bashrc_debug "Bash completion builtin not available; skipping"
        return 0
    fi

    base_bashrc_debug "sourcing Bash completions"
    # shellcheck source=/dev/null
    source "$completion_file"
}

base_bashrc_set_base_home || {
    printf 'ERROR: Unable to determine BASE_HOME from Base bashrc snippet. Run basectl update-profile.\n' >&2
    unset -f base_bashrc_debug base_bashrc_snippet_dir base_bashrc_source_baserc_guard base_bashrc_var_is_readonly
    return 1
}
base_bashrc_configure_path || return $?
base_bashrc_source_defaults || return 1
base_bashrc_source_completions || return 1
base_bashrc_debug "complete"

unset -f base_bashrc_snippet_dir base_bashrc_var_is_readonly base_bashrc_set_base_home
unset -f base_bashrc_source_platform_tools_helper base_bashrc_configure_path base_bashrc_source_defaults
unset -f base_bashrc_source_completions
unset -f base_bashrc_source_baserc_guard base_bashrc_debug
